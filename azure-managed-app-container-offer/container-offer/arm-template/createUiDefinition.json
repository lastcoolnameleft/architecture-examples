{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "location": {
          "label": "Location",
          "resourceTypes": ["Microsoft.ContainerService/managedClusters"]
        },
        "resourceGroup": {
          "allowExisting": true
        }
      }
    },
    "basics": [],
    "steps": [
      {
        "name": "clusterDetails",
        "label": "Cluster Details",
        "elements": [
          {
            "name": "clusterInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "text": "Select the AKS cluster where the Azure Voting App will be installed.",
              "style": "Info"
            }
          },
          {
            "name": "existingClusterSection",
            "type": "Microsoft.Common.Section",
            "label": "AKS Cluster",
            "elements": [
              {
                "name": "clusterLookupControl",
                "type": "Microsoft.Solutions.ArmApiControl",
                "request": {
                  "method": "GET",
                  "path": "[concat(subscription().id, '/providers/Microsoft.ContainerService/managedClusters?api-version=2023-10-01')]"
                }
              },
              {
                "name": "existingClusterResourceName",
                "type": "Microsoft.Common.DropDown",
                "label": "AKS Cluster Name",
                "toolTip": "AKS Cluster Resource Name",
                "constraints": {
                  "allowedValues": "[map(steps('clusterDetails').existingClusterSection.clusterLookupControl.value, (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]",
                  "required": true
                }
              }
            ],
            "visible": true
          }
        ]
      },
      {
        "name": "applicationDetails",
        "label": "Application Settings",
        "elements": [
          {
            "name": "extensionResourceName",
            "type": "Microsoft.Common.TextBox",
            "label": "Extension Name",
            "defaultValue": "azure-vote",
            "toolTip": "Name for the extension resource.",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9][a-z0-9-]{0,61}[a-z0-9]$",
              "validationMessage": "Must be lowercase alphanumeric with hyphens, 2-63 characters."
            }
          },
          {
            "name": "voteTitle",
            "type": "Microsoft.Common.TextBox",
            "label": "App Title",
            "defaultValue": "Azure Voting App",
            "toolTip": "Title displayed on the voting app",
            "constraints": {
              "required": true,
              "regex": "^.{1,64}$",
              "validationMessage": "Title must be between 1 and 64 characters."
            }
          },
          {
            "name": "voteValue1",
            "type": "Microsoft.Common.TextBox",
            "label": "Option 1",
            "defaultValue": "Cats",
            "toolTip": "First voting option",
            "constraints": {
              "required": true,
              "regex": "^.{1,32}$",
              "validationMessage": "Option must be between 1 and 32 characters."
            }
          },
          {
            "name": "voteValue2",
            "type": "Microsoft.Common.TextBox",
            "label": "Option 2",
            "defaultValue": "Dogs",
            "toolTip": "Second voting option",
            "constraints": {
              "required": true,
              "regex": "^.{1,32}$",
              "validationMessage": "Option must be between 1 and 32 characters."
            }
          }
        ]
      },
      {
        "name": "redisDetails",
        "label": "Redis Configuration",
        "elements": [
          {
            "name": "redisInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "text": "Configure Redis connectivity. Leave the host empty to deploy Redis in-cluster.",
              "style": "Info"
            }
          },
          {
            "name": "redisHost",
            "type": "Microsoft.Common.TextBox",
            "label": "Redis Host",
            "defaultValue": "",
            "toolTip": "External Redis hostname (e.g. myredis.redis.cache.windows.net). Leave empty for in-cluster Redis.",
            "constraints": {
              "required": false,
              "regex": "^[a-zA-Z0-9.-]*$",
              "validationMessage": "Must be a valid hostname (alphanumeric, dots, and hyphens only)."
            }
          },
          {
            "name": "redisPort",
            "type": "Microsoft.Common.TextBox",
            "label": "Redis Port",
            "defaultValue": "6379",
            "toolTip": "Redis port number (6379 for non-SSL, 6380 for SSL).",
            "constraints": {
              "required": true,
              "regex": "^[0-9]{1,5}$",
              "validationMessage": "Must be a valid port number (1-65535)."
            }
          },
          {
            "name": "redisSsl",
            "type": "Microsoft.Common.DropDown",
            "label": "Use SSL",
            "defaultValue": "false",
            "toolTip": "Enable SSL for Redis connections (required for Azure Cache for Redis).",
            "constraints": {
              "allowedValues": [
                { "label": "No", "value": "false" },
                { "label": "Yes", "value": "true" }
              ],
              "required": true
            }
          },
          {
            "name": "redisPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Redis Password",
              "confirmPassword": "Confirm Password"
            },
            "toolTip": "Redis access key. Leave empty if not required.",
            "constraints": {
              "required": false
            },
            "options": {
              "hideConfirmation": true
            }
          }
        ]
      }
    ],
    "outputs": {
      "clusterResourceName": "[steps('clusterDetails').existingClusterSection.existingClusterResourceName]",
      "extensionResourceName": "[steps('applicationDetails').extensionResourceName]",
      "vote_title": "[steps('applicationDetails').voteTitle]",
      "vote_value1": "[steps('applicationDetails').voteValue1]",
      "vote_value2": "[steps('applicationDetails').voteValue2]",
      "redis_host": "[steps('redisDetails').redisHost]",
      "redis_port": "[steps('redisDetails').redisPort]",
      "redis_ssl": "[steps('redisDetails').redisSsl]",
      "redis_password": "[steps('redisDetails').redisPassword]"
    }
  }
}
